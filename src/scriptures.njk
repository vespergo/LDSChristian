<script>
  /* Nav toggle (mobile) */
  document.querySelectorAll('.nav-toggle').forEach(btn => {
    btn.addEventListener('click', () => {
      const group = btn.closest('.nav-group');
      const isActive = group.classList.contains('active');
      document.querySelectorAll('.nav-group').forEach(g => g.classList.remove('active'));
      if (!isActive) group.classList.add('active');
    });
  });

  /* Filter + search */
  const cards = Array.from(document.querySelectorAll('.verse-card'));
  const sections = { bible: document.getElementById('grid-bible'), bom: document.getElementById('grid-bom'), dc: document.getElementById('grid-dc'), pgp: document.getElementById('grid-pgp') };
  const sectionHeads = Array.from(document.querySelectorAll('.section-head[data-section]'));
  const noResults = document.getElementById('no-results');
  let activeFilter = 'all';
  let activeSearch = '';

  function applyFilters() {
    let anyVisible = false;
    cards.forEach(card => {
      const src = card.dataset.source;
      const txt = (card.dataset.text + ' ' + card.textContent).toLowerCase();
      const matchFilter = activeFilter === 'all' || src === activeFilter;
      const matchSearch = !activeSearch || txt.includes(activeSearch);
      const show = matchFilter && matchSearch;
      card.hidden = !show;
      if (show) anyVisible = true;
    });

    /* Show/hide section heads based on whether their grid has visible cards */
    sectionHeads.forEach(head => {
      const sec = head.dataset.section;
      const grid = sections[sec];
      const hasVisible = Array.from(grid.querySelectorAll('.verse-card')).some(c => !c.hidden);
      head.style.display = hasVisible ? '' : 'none';
    });

    noResults.style.display = anyVisible ? 'none' : 'block';
  }

  document.querySelectorAll('.filter-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      activeFilter = btn.dataset.filter;
      applyFilters();
    });
  });

  document.getElementById('scripture-search').addEventListener('input', e => {
    activeSearch = e.target.value.trim().toLowerCase();
    applyFilters();
  });
</script>
{% endblock %}
