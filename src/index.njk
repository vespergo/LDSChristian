---
title: "LDS & Mainstream Christianity: Similarities & Differences"
navPage:
navGroup:
---
{% extends "base.njk" %}

{% block pageStyles %}
<style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --blue:    #1a4f8a;
      --gold:    #c8972b;
      --green:   #2d7a4f;
      --red:     #8a1a1a;
      --bg:      #f5f3ee;
      --card:    #ffffff;
      --text:    #1e1e1e;
      --muted:   #5c5c5c;
      --radius:  10px;
      --shadow:  0 2px 12px rgba(0,0,0,0.09);
    }

    body {
      font-family: Georgia, 'Times New Roman', serif;
      background: var(--bg);
      color: var(--text);
      line-height: 1.7;
    }

    /* ── Header ── */
    header {
      background: linear-gradient(135deg, var(--blue) 0%, #0d2f57 100%);
      color: #fff;
      text-align: center;
      padding: 3.5rem 1.5rem 2.5rem;
    }
    header .cross-icon {
      font-size: 2.8rem;
      display: block;
      margin-bottom: 0.5rem;
      opacity: 0.85;
    }
    header h1 {
      font-size: clamp(1.6rem, 4vw, 2.6rem);
      font-weight: 700;
      letter-spacing: 0.02em;
      margin-bottom: 0.6rem;
    }
    header p {
      font-size: 1.05rem;
      opacity: 0.8;
      max-width: 620px;
      margin: 0 auto;
    }

    /* ── Layout ── */
    main {
      max-width: 1100px;
      margin: 0 auto;
      padding: 2.5rem 1.25rem 4rem;
    }

    /* ── Section labels ── */
    .section-label {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      font-size: 0.78rem;
      font-family: system-ui, sans-serif;
      font-weight: 700;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      margin-bottom: 1.25rem;
    }
    .section-label::after {
      content: '';
      flex: 1;
      height: 2px;
      border-radius: 2px;
    }
    .section-label.sim  { color: var(--green); }
    .section-label.sim::after  { background: var(--green); opacity: 0.3; }
    .section-label.diff { color: var(--red); }
    .section-label.diff::after { background: var(--red);   opacity: 0.3; }

    /* ── Intro banner ── */
    .intro-banner {
      background: var(--card);
      border-left: 4px solid var(--gold);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      padding: 1.4rem 1.6rem;
      margin-bottom: 2.5rem;
      font-size: 1rem;
      color: var(--muted);
    }
    .intro-banner strong { color: var(--text); }

    /* ── Card grid ── */
    .card-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
      gap: 1.25rem;
      margin-bottom: 3rem;
    }

    .card {
      background: var(--card);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      padding: 1.4rem 1.5rem;
      border-top: 4px solid transparent;
      transition: transform 0.15s, box-shadow 0.15s;
    }
    .card:hover {
      transform: translateY(-3px);
      box-shadow: 0 6px 20px rgba(0,0,0,0.13);
    }
    .card.sim  { border-top-color: var(--green); }
    .card.diff { border-top-color: var(--red); }

    .card-icon {
      font-size: 1.8rem;
      margin-bottom: 0.5rem;
      display: block;
    }
    .card h3 {
      font-size: 1.05rem;
      font-weight: 700;
      margin-bottom: 0.4rem;
      color: var(--text);
    }
    .card p {
      font-size: 0.93rem;
      color: var(--muted);
      line-height: 1.6;
    }

    /* ── Side-by-side comparison table ── */
    .compare-section {
      margin-bottom: 3rem;
    }
    .compare-section h2 {
      font-size: 1.3rem;
      font-family: system-ui, sans-serif;
      font-weight: 700;
      color: var(--blue);
      margin-bottom: 1rem;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .compare-table {
      width: 100%;
      border-collapse: separate;
      border-spacing: 0;
      border-radius: var(--radius);
      overflow: hidden;
      box-shadow: var(--shadow);
      font-size: 0.93rem;
    }
    .compare-table thead {
      background: var(--blue);
      color: #fff;
    }
    .compare-table thead th {
      padding: 0.85rem 1.1rem;
      text-align: left;
      font-family: system-ui, sans-serif;
      font-weight: 600;
      letter-spacing: 0.03em;
    }
    .compare-table thead th:first-child { width: 22%; background: #0d2f57; }
    .compare-table tbody tr:nth-child(even) td { background: #f0ede8; }
    .compare-table tbody tr:nth-child(odd)  td { background: #fff; }
    .compare-table tbody tr:hover td { background: #e8eef7; }
    .compare-table td {
      padding: 0.8rem 1.1rem;
      vertical-align: top;
      border-bottom: 1px solid #e4dfd8;
      color: var(--text);
    }
    .compare-table td:first-child {
      font-family: system-ui, sans-serif;
      font-weight: 700;
      font-size: 0.82rem;
      color: var(--blue);
      white-space: nowrap;
    }
    .compare-table td.lds-col  { border-left: 3px solid var(--gold); }
    .compare-table td.main-col { border-left: 3px solid #9ab; }

    /* column headers within the table */
    .compare-table thead th.lds-head  { background: #1e5a9e; }
    .compare-table thead th.main-head { background: #2e6b8a; }

    /* ── Quick-reference pills ── */
    .pill-row {
      display: flex;
      flex-wrap: wrap;
      gap: 0.55rem;
      margin-bottom: 3rem;
    }
    .pill {
      display: inline-block;
      padding: 0.35rem 0.85rem;
      border-radius: 999px;
      font-family: system-ui, sans-serif;
      font-size: 0.82rem;
      font-weight: 600;
    }
    .pill.shared {
      background: #d6efe2;
      color: var(--green);
      border: 1px solid #a5d4bc;
    }

    /* ── Footer ── */
    footer {
      text-align: center;
      font-family: system-ui, sans-serif;
      font-size: 0.82rem;
      color: var(--muted);
      padding: 1.5rem;
      border-top: 1px solid #ddd8d0;
    }

    /* ── Nav ── */
    .topnav { background: #0d2f57; padding: 0 1.5rem; display: flex; align-items: stretch; flex-wrap: wrap; min-height: 2.8rem; }
    .topnav a.home { color: #fff; font-weight: 700; text-decoration: none; font-family: system-ui, sans-serif; font-size: 0.85rem; padding: 0 0.9rem; display: flex; align-items: center; gap: 0.4rem; transition: background 0.15s; }
    .topnav a.home:hover { background: rgba(255,255,255,0.1); }
    .nav-item { color: #cde; text-decoration: none; font-family: system-ui, sans-serif; font-size: 0.82rem; font-weight: 600; padding: 0 0.9rem; min-height: 2.8rem; display: flex; align-items: center; gap: 0.35rem; transition: background 0.15s, color 0.15s; }
    .nav-item:hover { background: rgba(255,255,255,0.1); color: #fff; }
    .nav-group { position: relative; display: flex; align-items: stretch; }
    .nav-toggle { background: none; border: none; cursor: pointer; color: #cde; font-family: system-ui, sans-serif; font-size: 0.82rem; font-weight: 600; padding: 0 0.9rem; min-height: 2.8rem; display: flex; align-items: center; gap: 0.35rem; transition: background 0.15s, color 0.15s; }
    .nav-toggle:hover, .nav-group:hover .nav-toggle, .nav-group:focus-within .nav-toggle { background: rgba(255,255,255,0.1); color: #fff; }
    .nav-group.active .nav-toggle { color: #fff; background: rgba(255,255,255,0.14); }
    .nav-caret { font-size: 0.6rem; transition: transform 0.2s; }
    .nav-group:hover .nav-caret, .nav-group:focus-within .nav-caret { transform: rotate(180deg); }
    .nav-dropdown { display: none; position: absolute; top: 100%; left: 0; background: #112a4a; border: 1px solid rgba(255,255,255,0.1); border-radius: 0 0 8px 8px; min-width: 210px; box-shadow: 0 8px 24px rgba(0,0,0,0.35); z-index: 200; }
    .nav-group:hover .nav-dropdown, .nav-group:focus-within .nav-dropdown { display: block; }
    .nav-dropdown a { display: block; color: #cde; text-decoration: none; font-family: system-ui, sans-serif; font-size: 0.83rem; padding: 0.6rem 1.1rem; transition: background 0.12s, color 0.12s; white-space: nowrap; border-bottom: 1px solid rgba(255,255,255,0.06); }
    .nav-dropdown a:last-child { border-bottom: none; }
    .nav-dropdown a:hover { background: rgba(255,255,255,0.1); color: #fff; }
    .nav-dropdown a.active { color: #ffd080; font-weight: 700; }

    /* ── Subpage links ── */
    .subpage-section { margin-bottom: 3rem; }
    .subpage-section h2 { font-size: 1.25rem; font-family: system-ui, sans-serif; font-weight: 700; color: var(--blue); margin-bottom: 1rem; display: flex; align-items: center; gap: 0.5rem; }
    .subpage-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.25rem; }
    .subpage-card { display: block; text-decoration: none; background: var(--card); border-radius: var(--radius); box-shadow: var(--shadow); padding: 1.5rem 1.6rem; border-top: 5px solid transparent; transition: transform 0.15s, box-shadow 0.15s; }
    .subpage-card:hover { transform: translateY(-4px); box-shadow: 0 8px 24px rgba(0,0,0,0.15); }
    .subpage-card.catholic { border-top-color: #8b1a2e; }
    .subpage-card.orthodox { border-top-color: #5a2d82; }
    .subpage-card.protestant { border-top-color: #1a6b3a; }
    .subpage-card .sp-icon { font-size: 2.2rem; display: block; margin-bottom: 0.5rem; }
    .subpage-card h3 { font-size: 1.05rem; font-weight: 700; margin-bottom: 0.3rem; }
    .subpage-card.catholic h3 { color: #8b1a2e; }
    .subpage-card.orthodox h3 { color: #5a2d82; }
    .subpage-card.protestant h3 { color: #1a6b3a; }
    .subpage-card p { font-size: 0.88rem; color: var(--muted); line-height: 1.55; margin-bottom: 0.9rem; }
    .subpage-card .sp-link { font-family: system-ui, sans-serif; font-size: 0.82rem; font-weight: 700; letter-spacing: 0.04em; }
    .subpage-card.catholic .sp-link { color: #8b1a2e; }
    .subpage-card.orthodox .sp-link { color: #5a2d82; }
    .subpage-card.protestant .sp-link { color: #1a6b3a; }

    /* ── Responsive ── */
    @media (max-width: 600px) {
      .compare-table { font-size: 0.82rem; }
      .compare-table td, .compare-table thead th { padding: 0.65rem 0.7rem; }
      .compare-table td:first-child { white-space: normal; }
    }
  </style>
{% endblock %}

{% block content %}
<header>
  <span class="cross-icon"><i class="fa-solid fa-cross"></i></span>
  <h1>LDS &amp; Mainstream Christianity</h1>
  <p>A comparative overview of shared beliefs and key doctrinal distinctions between The Church of Jesus Christ of Latter-day Saints and traditional Christian denominations.</p>
</header>

<main>

  <!-- Intro -->
  <div class="intro-banner">
    <strong>Note on terminology:</strong> "Mainstream Christianity" refers broadly to Catholic, Protestant, and Eastern Orthodox traditions that affirm the ecumenical creeds (Nicene, Apostles'). The LDS Church considers itself Christian but represents a <em>Restoration</em> movement with distinct theology that departs from creedal Christianity on several foundational points.
  </div>

  <!-- ══════════ SIMILARITIES ══════════ -->
  <div class="section-label sim"><i class="fa-solid fa-check"></i> &nbsp;Shared Beliefs &amp; Common Ground</div>

  <!-- Quick pill list of shared things -->
  <div class="pill-row">
    <span class="pill shared">Jesus Christ as Savior</span>
    <span class="pill shared">God the Father</span>
    <span class="pill shared">Holy Ghost / Holy Spirit</span>
    <span class="pill shared">Bible (Old &amp; New Testament)</span>
    <span class="pill shared">Baptism</span>
    <span class="pill shared">Prayer</span>
    <span class="pill shared">Resurrection</span>
    <span class="pill shared">Life after death</span>
    <span class="pill shared">Moral law &amp; Ten Commandments</span>
    <span class="pill shared">Golden Rule</span>
    <span class="pill shared">Service &amp; charity</span>
    <span class="pill shared">Missionary work</span>
    <span class="pill shared">Sin &amp; repentance</span>
    <span class="pill shared">Grace of God</span>
    <span class="pill shared">Communion / Sacrament</span>
    <span class="pill shared">Eternal life</span>
  </div>

  <div class="card-grid">

    <div class="card sim">
      <span class="card-icon"><i class="fa-solid fa-hands-praying"></i></span>
      <h3>Jesus Christ as Lord and Savior</h3>
      <p>Both traditions affirm that Jesus Christ is the Son of God who atoned for humanity's sins through His suffering, death, and resurrection, making salvation possible for all people.</p>
    </div>

    <div class="card sim">
      <span class="card-icon"><i class="fa-solid fa-book-bible"></i></span>
      <h3>The Holy Bible</h3>
      <p>LDS members use the Bible (typically the King James Version) as foundational scripture alongside additional texts. Like mainstream Christians, they view the Bible as the word of God and central to faith and worship.</p>
    </div>

    <div class="card sim">
      <span class="card-icon"><i class="fa-solid fa-droplet"></i></span>
      <h3>Baptism</h3>
      <p>Both traditions practice baptism as an ordinance of initiation into the faith and a symbol of the washing away of sin. LDS baptism is by full immersion, a practice also common in Baptist and other Protestant traditions.</p>
    </div>

    <div class="card sim">
      <span class="card-icon"><i class="fa-solid fa-wine-glass"></i></span>
      <h3>The Sacrament / Communion</h3>
      <p>Both observe a ritual remembrance of Christ's Last Supper — bread and water (LDS) or bread and wine/grape juice (mainstream) — commemorating the Atonement and renewing commitment to God.</p>
    </div>

    <div class="card sim">
      <span class="card-icon"><i class="fa-solid fa-pen-nib"></i></span>
      <h3>Prayer &amp; Personal Revelation</h3>
      <p>Prayer is central in both traditions. Believers in both camps seek personal guidance from God, believe He hears and answers prayer, and are encouraged to maintain an active, ongoing relationship with Him.</p>
    </div>

    <div class="card sim">
      <span class="card-icon"><i class="fa-solid fa-bookmark"></i></span>
      <h3>Sin, Repentance &amp; Forgiveness</h3>
      <p>Both teach that all humans sin, that repentance is necessary, and that God's grace and forgiveness are available through Christ. Moral accountability before God is a shared cornerstone of both theologies.</p>
    </div>

    <div class="card sim">
      <span class="card-icon"><i class="fa-solid fa-sun"></i></span>
      <h3>Resurrection &amp; Life After Death</h3>
      <p>Both affirm the bodily resurrection of Jesus Christ and believe in a literal resurrection for all humanity. Life after death, judgment, and the promise of eternal life are core to both faiths.</p>
    </div>

    <div class="card sim">
      <span class="card-icon"><i class="fa-solid fa-heart"></i></span>
      <h3>Moral &amp; Ethical Teaching</h3>
      <p>Both emphasize the Ten Commandments, the Golden Rule ("do unto others"), chastity, honesty, sobriety, service to others, and love for God and neighbor as the basis of a righteous life.</p>
    </div>

    <div class="card sim">
      <span class="card-icon"><i class="fa-solid fa-globe"></i></span>
      <h3>Missionary &amp; Evangelism Emphasis</h3>
      <p>Both traditions place a high value on sharing their faith with others. The LDS Church sends tens of thousands of full-time missionaries worldwide; mainstream denominations likewise support active evangelism programs.</p>
    </div>

  </div>

  <!-- ══════════ DIFFERENCES ══════════ -->
  <div class="section-label diff"><i class="fa-solid fa-not-equal"></i> &nbsp;Key Doctrinal Differences</div>

  <div class="card-grid">

    <div class="card diff">
      <span class="card-icon"><i class="fa-solid fa-diagram-project"></i></span>
      <h3>Nature of God: Godhead vs. Trinity</h3>
      <p>Mainstream Christianity holds that God the Father, Son, and Holy Spirit are <em>one substance</em> (the Trinity). LDS theology teaches they are <em>three separate, distinct beings</em> — the Godhead — united in purpose but not in substance.</p>
    </div>

    <div class="card diff">
      <span class="card-icon"><i class="fa-solid fa-book-open"></i></span>
      <h3>Additional Scripture</h3>
      <p>LDS members accept the Book of Mormon, Doctrine &amp; Covenants, and Pearl of Great Price as scripture alongside the Bible. Mainstream Christianity holds the Bible as the sole (or primary) closed canon of scripture.</p>
    </div>

    <div class="card diff">
      <span class="card-icon"><i class="fa-solid fa-star"></i></span>
      <h3>Pre-mortal Existence</h3>
      <p>LDS doctrine teaches that all human souls existed as spirit children of God before birth on earth. Mainstream Christianity generally holds that souls are created at conception and have no prior existence.</p>
    </div>

    <div class="card diff">
      <span class="card-icon"><i class="fa-solid fa-crown"></i></span>
      <h3>Living Prophet &amp; Continuing Revelation</h3>
      <p>The LDS Church is led by a living prophet believed to receive revelation from God for the whole church. Mainstream Christianity generally holds that public revelation ended with the apostolic age.</p>
    </div>

    <div class="card diff">
      <span class="card-icon"><i class="fa-solid fa-place-of-worship"></i></span>
      <h3>Temple Ordinances</h3>
      <p>LDS temples are distinct from meetinghouses — sacred spaces where special saving ordinances (endowment, celestial marriage, proxy baptism for the dead) are performed. Mainstream churches have no equivalent.</p>
    </div>

    <div class="card diff">
      <span class="card-icon"><i class="fa-solid fa-ring"></i></span>
      <h3>Eternal (Celestial) Marriage</h3>
      <p>LDS theology teaches that marriages sealed in the temple can endure for eternity. Mainstream Christianity, citing Mark 12:25, generally holds that marriage is an earthly institution that ends at death.</p>
    </div>

    <div class="card diff">
      <span class="card-icon"><i class="fa-solid fa-star"></i></span>
      <h3>Three Degrees of Glory</h3>
      <p>LDS afterlife theology includes three heavenly kingdoms (Celestial, Terrestrial, Telestial) plus Outer Darkness. Mainstream Christianity typically teaches Heaven or Hell (with some traditions including Purgatory).</p>
    </div>

    <div class="card diff">
      <span class="card-icon"><i class="fa-solid fa-rotate-left"></i></span>
      <h3>The Great Apostasy &amp; Restoration</h3>
      <p>LDS doctrine holds that the original church Christ established fell into apostasy after the early apostles died, requiring a <em>Restoration</em> through Joseph Smith. Mainstream Christianity rejects the concept of a total apostasy.</p>
    </div>

    <div class="card diff">
      <span class="card-icon"><i class="fa-solid fa-key"></i></span>
      <h3>Priesthood Authority</h3>
      <p>LDS members believe the Melchizedek and Aaronic priesthoods were restored through Joseph Smith, giving the LDS Church exclusive authority to perform saving ordinances. Most Protestant traditions hold that all believers share the priesthood.</p>
    </div>

    <div class="card diff">
      <span class="card-icon"><i class="fa-solid fa-mug-hot"></i></span>
      <h3>Word of Wisdom (Health Code)</h3>
      <p>LDS members follow a health code that prohibits coffee, tea, alcohol, and tobacco. While some mainstream denominations discourage alcohol, no comparable universal code exists across mainstream Christianity.</p>
    </div>

    <div class="card diff">
      <span class="card-icon"><i class="fa-solid fa-lightbulb"></i></span>
      <h3>Human Potential &amp; Exaltation</h3>
      <p>LDS theology includes the concept that faithful humans can progress to become like God ("as God now is, man may become"). This doctrine of deification has no mainstream equivalent, though Eastern Orthodoxy teaches a related concept of <em>theosis</em>.</p>
    </div>

    <div class="card diff">
      <span class="card-icon"><i class="fa-solid fa-hand-holding-dollar"></i></span>
      <h3>Tithing as a Commandment</h3>
      <p>LDS members are required to pay a full 10% tithe to remain in good standing for temple attendance. While most denominations encourage tithing, it is not typically a condition for full participation.</p>
    </div>

  </div>

  <!-- ══════════ SIDE-BY-SIDE TABLE ══════════ -->
  <div class="compare-section">
    <h2><i class="fa-solid fa-table-columns"></i> &nbsp;Side-by-Side Comparison</h2>
    <div style="overflow-x:auto;">
      <table class="compare-table">
        <thead>
          <tr>
            <th>Topic</th>
            <th class="lds-head">LDS (Latter-day Saints)</th>
            <th class="main-head">Mainstream Christianity</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>Nature of God</td>
            <td class="lds-col">Father, Son &amp; Holy Ghost are three distinct, separate beings united in purpose</td>
            <td class="main-col">One God in three persons (Trinity) — same substance, eternally coexistent</td>
          </tr>
          <tr>
            <td>Scripture</td>
            <td class="lds-col">Bible + Book of Mormon + D&amp;C + Pearl of Great Price (open canon)</td>
            <td class="main-col">Bible only (Old &amp; New Testament); closed canon</td>
          </tr>
          <tr>
            <td>Jesus Christ</td>
            <td class="lds-col">Son of God, Savior, Jehovah of the Old Testament; a separate being from the Father</td>
            <td class="main-col">Son of God, Savior, second person of the Trinity; fully God and fully man</td>
          </tr>
          <tr>
            <td>Holy Spirit</td>
            <td class="lds-col">A separate, distinct personage of spirit; the third member of the Godhead</td>
            <td class="main-col">Third person of the Trinity; same substance as Father and Son</td>
          </tr>
          <tr>
            <td>Salvation</td>
            <td class="lds-col">Grace + ordinances + personal righteousness; degrees of glory in the afterlife</td>
            <td class="main-col">Primarily grace through faith (Protestantism) or grace + sacraments (Catholic/Orthodox)</td>
          </tr>
          <tr>
            <td>Afterlife</td>
            <td class="lds-col">Three kingdoms of glory (Celestial, Terrestrial, Telestial) + Outer Darkness</td>
            <td class="main-col">Heaven and Hell (some: Purgatory); no tiered heavenly kingdoms</td>
          </tr>
          <tr>
            <td>Pre-earth Life</td>
            <td class="lds-col">All souls lived as spirit children of God before mortality</td>
            <td class="main-col">Souls created at conception; no pre-mortal existence</td>
          </tr>
          <tr>
            <td>Authority</td>
            <td class="lds-col">Priesthood restored through Joseph Smith; exclusive saving authority claimed</td>
            <td class="main-col">Authority through ordination, apostolic succession (Catholic/Orthodox), or universal priesthood (Protestant)</td>
          </tr>
          <tr>
            <td>Continuing Revelation</td>
            <td class="lds-col">Living prophet and apostles receive ongoing revelation; doctrine can be updated</td>
            <td class="main-col">Revelation closed with the apostolic age; scripture is complete</td>
          </tr>
          <tr>
            <td>Temple</td>
            <td class="lds-col">Sacred buildings for exclusive saving ordinances (endowments, sealings, proxy baptism)</td>
            <td class="main-col">Churches/cathedrals open to all; no equivalent secret or exclusive ordinances</td>
          </tr>
          <tr>
            <td>Baptism</td>
            <td class="lds-col">By immersion at age 8+; proxy baptism for deceased ancestors</td>
            <td class="main-col">Varies: infant or believer's baptism; immersion, sprinkling, or pouring; no proxy practice</td>
          </tr>
          <tr>
