---
title: "Glossary of LDS & Christian Terms"
navPage: glossary
navGroup: reference
---
{% extends "base.njk" %}

{% block pageStyles %}
<style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --blue:    #1a4f8a;
      --gold:    #c8972b;
      --green:   #2d7a4f;
      --red:     #8a1a1a;
      --bg:      #f5f3ee;
      --card:    #ffffff;
      --text:    #1e1e1e;
      --muted:   #5c5c5c;
      --radius:  10px;
      --shadow:  0 2px 12px rgba(0,0,0,0.09);
    }
    body { font-family: Georgia, 'Times New Roman', serif; background: var(--bg); color: var(--text); line-height: 1.7; }

    .topnav { background: #0d2f57; padding: 0 1.5rem; display: flex; align-items: stretch; flex-wrap: wrap; min-height: 2.8rem; }
    .topnav a.home { color: #fff; font-weight: 700; text-decoration: none; font-family: system-ui, sans-serif; font-size: 0.85rem; padding: 0 0.9rem; display: flex; align-items: center; gap: 0.4rem; transition: background 0.15s; }
    .topnav a.home:hover { background: rgba(255,255,255,0.1); }
    .nav-item { color: #cde; text-decoration: none; font-family: system-ui, sans-serif; font-size: 0.82rem; font-weight: 600; padding: 0 0.9rem; min-height: 2.8rem; display: flex; align-items: center; gap: 0.35rem; transition: background 0.15s, color 0.15s; }
    .nav-item:hover { background: rgba(255,255,255,0.1); color: #fff; }
    .nav-group { position: relative; display: flex; align-items: stretch; }
    .nav-toggle { background: none; border: none; cursor: pointer; color: #cde; font-family: system-ui, sans-serif; font-size: 0.82rem; font-weight: 600; padding: 0 0.9rem; min-height: 2.8rem; display: flex; align-items: center; gap: 0.35rem; transition: background 0.15s, color 0.15s; }
    .nav-toggle:hover, .nav-group:hover .nav-toggle, .nav-group:focus-within .nav-toggle { background: rgba(255,255,255,0.1); color: #fff; }
    .nav-group.active .nav-toggle { color: #fff; background: rgba(255,255,255,0.14); }
    .nav-caret { font-size: 0.6rem; transition: transform 0.2s; }
    .nav-group:hover .nav-caret, .nav-group:focus-within .nav-caret { transform: rotate(180deg); }
    .nav-dropdown { display: none; position: absolute; top: 100%; left: 0; background: #112a4a; border: 1px solid rgba(255,255,255,0.1); border-radius: 0 0 8px 8px; min-width: 210px; box-shadow: 0 8px 24px rgba(0,0,0,0.35); z-index: 200; }
    .nav-group:hover .nav-dropdown, .nav-group:focus-within .nav-dropdown { display: block; }
    .nav-dropdown a { display: block; color: #cde; text-decoration: none; font-family: system-ui, sans-serif; font-size: 0.83rem; padding: 0.6rem 1.1rem; transition: background 0.12s, color 0.12s; white-space: nowrap; border-bottom: 1px solid rgba(255,255,255,0.06); }
    .nav-dropdown a:last-child { border-bottom: none; }
    .nav-dropdown a:hover { background: rgba(255,255,255,0.1); color: #fff; }
    .nav-dropdown a.active { color: #ffd080; font-weight: 700; }

    header { background: linear-gradient(135deg, #3a2a6b 0%, #1a0a3a 100%); color: #fff; text-align: center; padding: 3rem 1.5rem 2.2rem; }
    header .icon { font-size: 2.8rem; display: block; margin-bottom: 0.4rem; }
    header h1 { font-size: clamp(1.5rem, 3.5vw, 2.5rem); font-weight: 700; margin-bottom: 0.5rem; }
    header p { font-size: 1rem; opacity: 0.82; max-width: 650px; margin: 0 auto; }

    main { max-width: 900px; margin: 0 auto; padding: 2.5rem 1.25rem 4rem; }

    .intro-banner { background: var(--card); border-left: 4px solid var(--gold); border-radius: var(--radius); box-shadow: var(--shadow); padding: 1.2rem 1.5rem; margin-bottom: 1.5rem; font-size: 0.98rem; color: var(--muted); }
    .intro-banner strong { color: var(--text); }

    /* Search box */
    .search-wrap { position: relative; margin-bottom: 1.5rem; }
    .search-wrap i { position: absolute; left: 1rem; top: 50%; transform: translateY(-50%); color: var(--muted); }
    #glossary-search { width: 100%; font-family: system-ui, sans-serif; font-size: 0.95rem; padding: 0.8rem 1rem 0.8rem 2.6rem; border: 1px solid #ddd6cc; border-radius: var(--radius); background: var(--card); color: var(--text); box-shadow: var(--shadow); }
    #glossary-search:focus { outline: 2px solid var(--blue); outline-offset: 1px; }

    /* Alphabet nav */
    .alpha-nav { display: flex; flex-wrap: wrap; gap: 0.3rem; margin-bottom: 2rem; }
    .alpha-nav a { font-family: system-ui, sans-serif; font-size: 0.8rem; font-weight: 700; text-decoration: none; color: var(--blue); background: var(--card); border: 1px solid #ddd6cc; border-radius: 6px; width: 1.9rem; height: 1.9rem; display: flex; align-items: center; justify-content: center; transition: background 0.15s, color 0.15s; }
    .alpha-nav a:hover { background: var(--blue); color: #fff; }

    .letter-group { margin-bottom: 1.8rem; scroll-margin-top: 1rem; }
    .letter-head { font-family: system-ui, sans-serif; font-size: 1.4rem; font-weight: 800; color: var(--gold); margin-bottom: 0.6rem; border-bottom: 2px solid rgba(200,151,43,0.25); padding-bottom: 0.2rem; }

    .term { background: var(--card); border-radius: var(--radius); box-shadow: var(--shadow); padding: 1.1rem 1.4rem; margin-bottom: 0.8rem; border-left: 4px solid var(--blue); }
    .term.lds { border-left-color: var(--gold); }
    .term.main { border-left-color: var(--red); }
    .term dt { font-size: 1.02rem; font-weight: 700; color: var(--text); margin-bottom: 0.15rem; display: flex; align-items: center; gap: 0.6rem; flex-wrap: wrap; }
    .term .badge { font-family: system-ui, sans-serif; font-size: 0.68rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; padding: 0.12rem 0.5rem; border-radius: 4px; }
    .term .badge.lds  { background: #f3e6c4; color: #8a6000; }
    .term .badge.main { background: #f3d6d6; color: var(--red); }
    .term .badge.shared { background: #d6efe2; color: var(--green); }
    .term dd { font-size: 0.92rem; color: var(--muted); line-height: 1.65; }
    .term dd a { color: var(--blue); }

    .no-results { display: none; text-align: center; font-family: system-ui, sans-serif; color: var(--muted); padding: 2rem; }

    footer { text-align: center; font-family: system-ui, sans-serif; font-size: 0.82rem; color: var(--muted); padding: 1.5rem; border-top: 1px solid #ddd8d0; }
  </style>
{% endblock %}

{% block content %}
<header>
  <span class="icon"><i class="fa-solid fa-book-open"></i></span>
  <h1>Glossary of Terms</h1>
  <p>Definitions for the LDS and Christian vocabulary used throughout this site — color-coded by tradition. Type to filter.</p>
</header>

<main>

  <div class="intro-banner">
    <strong>Color key:</strong>
    <span class="term-key" style="color:#8a6000; font-weight:700;">Gold = LDS-specific</span> ·
    <span style="color:var(--red); font-weight:700;">Red = Mainstream Christian</span> ·
    <span style="color:var(--green); font-weight:700;">Green = Shared</span> ·
    <span style="color:var(--blue); font-weight:700;">Blue = General</span>
  </div>

  <div class="search-wrap">
    <i class="fa-solid fa-magnifying-glass"></i>
    <input type="text" id="glossary-search" placeholder="Search terms… (e.g. endowment, theosis, ward)" aria-label="Search glossary terms" />
  </div>

  <div class="alpha-nav" id="alpha-nav"></div>

  <div id="glossary">

    <!-- A -->
    <div class="letter-group" id="letter-a" data-letter="A">
      <div class="letter-head">A</div>
      <dl class="term lds"><dt>Aaronic Priesthood <span class="badge lds">LDS</span></dt><dd>The lesser of the two LDS priesthoods, associated with preparatory ordinances like baptism and the sacrament. Young men typically begin holding it around age 11–12. Named after Aaron, brother of Moses.</dd></dl>
      <dl class="term"><dt>Apostasy, The Great <span class="badge lds">LDS</span></dt><dd>The LDS belief that the original church established by Christ fell into doctrinal corruption after the death of the apostles, losing priesthood authority — the condition that necessitated the Restoration.</dd></dl>
      <dl class="term shared"><dt>Atonement <span class="badge shared">Shared</span></dt><dd>The redemptive work of Jesus Christ — His suffering, death, and resurrection — by which humanity can be reconciled to God. Central to both LDS and mainstream Christianity.</dd></dl>
    </div>

    <!-- B -->
    <div class="letter-group" id="letter-b" data-letter="B">
      <div class="letter-head">B</div>
      <dl class="term shared"><dt>Baptism for the Dead <span class="badge lds">LDS</span></dt><dd>A temple ordinance in which a living member is baptized by proxy on behalf of a deceased ancestor, offering them the choice to accept the ordinance in the afterlife. Based on 1 Corinthians 15:29.</dd></dl>
      <dl class="term"><dt>Bishop <span class="badge lds">LDS</span></dt><dd>The unpaid volunteer leader of a local LDS congregation (ward), roughly equivalent to a pastor or priest in other churches but serving while keeping a regular job.</dd></dl>
      <dl class="term lds"><dt>Book of Mormon <span class="badge lds">LDS</span></dt><dd>A volume of LDS scripture, subtitled "Another Testament of Jesus Christ," which Latter-day Saints believe Joseph Smith translated from ancient golden plates. It recounts peoples in the ancient Americas and Christ's visit to them.</dd></dl>
      <dl class="term"><dt>Branch <span class="badge lds">LDS</span></dt><dd>A small LDS congregation, smaller than a ward, often in areas with fewer members.</dd></dl>
    </div>

    <!-- C -->
    <div class="letter-group" id="letter-c" data-letter="C">
      <div class="letter-head">C</div>
      <dl class="term lds"><dt>Calling <span class="badge lds">LDS</span></dt><dd>A volunteer assignment to serve in the church — teaching, leadership, music, and so on. Because there is no paid local clergy, callings staff the entire congregation.</dd></dl>
      <dl class="term lds"><dt>Celestial Kingdom <span class="badge lds">LDS</span></dt><dd>The highest of the three "degrees of glory" in LDS afterlife theology, where the faithful dwell in God's presence. (See also Terrestrial and Telestial kingdoms.)</dd></dl>
      <dl class="term"><dt>Community of Christ <span class="badge lds">LDS</span></dt><dd>Formerly the RLDS Church; a separate denomination descending from the same 1830 origin that followed Joseph Smith's descendants rather than Brigham Young. More theologically mainstream than the Utah-based church.</dd></dl>
      <dl class="term main"><dt>Creed <span class="badge main">Mainstream</span></dt><dd>An authoritative statement of belief, such as the Nicene or Apostles' Creed. Mainstream Christianity affirms these; LDS theology rejects them as products of the Apostasy.</dd></dl>
    </div>

    <!-- D -->
    <div class="letter-group" id="letter-d" data-letter="D">
      <div class="letter-head">D</div>
      <dl class="term lds"><dt>Doctrine &amp; Covenants <span class="badge lds">LDS</span></dt><dd>A book of LDS scripture consisting mainly of revelations given to Joseph Smith and later church presidents. One of the four "standard works."</dd></dl>
    </div>

    <!-- E -->
    <div class="letter-group" id="letter-e" data-letter="E">
      <div class="letter-head">E</div>
      <dl class="term lds"><dt>Endowment <span class="badge lds">LDS</span></dt><dd>A sacred temple ceremony in which participants receive instruction and make covenants with God. Considered essential preparation for exaltation.</dd></dl>
      <dl class="term lds"><dt>Exaltation <span class="badge lds">LDS</span></dt><dd>The LDS doctrine that the faithful may progress to become like God, inheriting His glory and "all that the Father hath." Distinct from general salvation; achieved through ordinances and faithfulness.</dd></dl>
    </div>

    <!-- F -->
    <div class="letter-group" id="letter-f" data-letter="F">
      <div class="letter-head">F</div>
      <dl class="term lds"><dt>First Vision <span class="badge lds">LDS</span></dt><dd>Joseph Smith's foundational 1820 experience in which he reported that God the Father and Jesus Christ appeared to him as two separate beings — the basis for the LDS view of the Godhead.</dd></dl>
      <dl class="term lds"><dt>FLDS <span class="badge lds">LDS</span></dt><dd>The Fundamentalist Church of Jesus Christ of Latter-Day Saints — a small breakaway sect that still practices polygamy. Not affiliated with the mainstream LDS Church.</dd></dl>
    </div>

    <!-- G -->
    <div class="letter-group" id="letter-g" data-letter="G">
      <div class="letter-head">G</div>
      <dl class="term lds"><dt>Garments <span class="badge lds">LDS</span></dt><dd>Modest undergarments worn by adults who have received the temple endowment, as a private reminder of sacred covenants.</dd></dl>
      <dl class="term lds"><dt>Godhead <span class="badge lds">LDS</span></dt><dd>The LDS conception of deity: the Father, the Son, and the Holy Ghost as three separate and distinct beings united in purpose — contrasted with the mainstream Trinity (one substance).</dd></dl>
    </div>

    <!-- H -->
    <div class="letter-group" id="letter-h" data-letter="H">
      <div class="letter-head">H</div>
      <dl class="term shared"><dt>Holy Ghost / Holy Spirit <span class="badge shared">Shared</span></dt><dd>The third member of the Godhead/Trinity. LDS regards the Holy Ghost as a distinct personage of spirit; mainstream Christianity as the third person of one triune God.</dd></dl>
    </div>

    <!-- M -->
    <div class="letter-group" id="letter-m" data-letter="M">
      <div class="letter-head">M</div>
      <dl class="term lds"><dt>Melchizedek Priesthood <span class="badge lds">LDS</span></dt><dd>The higher of the two LDS priesthoods, conferring authority to lead the church and perform higher ordinances. Named after the biblical priest-king Melchizedek.</dd></dl>
      <dl class="term lds"><dt>Manifesto (1890) <span class="badge lds">LDS</span></dt><dd>The official declaration by President Wilford Woodruff ending the practice of plural marriage in the church.</dd></dl>
      <dl class="term"><dt>Ministering <span class="badge lds">LDS</span></dt><dd>The program in which members are assigned to regularly watch over and support a few specific households.</dd></dl>
    </div>

    <!-- N -->
    <div class="letter-group" id="letter-n" data-letter="N">
      <div class="letter-head">N</div>
      <dl class="term main"><dt>Nicene Creed <span class="badge main">Mainstream</span></dt><dd>The 4th-century statement of faith (325/381 AD) defining God as one substance in three co-equal persons. The doctrinal benchmark of creedal Christianity, which LDS does not affirm.</dd></dl>
    </div>

    <!-- O -->
    <div class="letter-group" id="letter-o" data-letter="O">
      <div class="letter-head">O</div>
      <dl class="term shared"><dt>Ordinance <span class="badge lds">LDS</span></dt><dd>A sacred rite performed by priesthood authority — such as baptism, confirmation, the sacrament, the endowment, or sealing. Roughly parallel to a "sacrament" in other traditions.</dd></dl>
      <dl class="term lds"><dt>Outer Darkness <span class="badge lds">LDS</span></dt><dd>In LDS theology, the state reserved for the few who knowingly and fully reject God ("sons of perdition") — the closest LDS analogue to traditional Hell, but applying to very few.</dd></dl>
    </div>

    <!-- P -->
    <div class="letter-group" id="letter-p" data-letter="P">
      <div class="letter-head">P</div>
      <dl class="term lds"><dt>Pearl of Great Price <span class="badge lds">LDS</span></dt><dd>One of the four LDS "standard works," a short collection including the Book of Moses, the Book of Abraham, and Joseph Smith's own history.</dd></dl>
      <dl class="term lds"><dt>Pre-mortal Existence <span class="badge lds">LDS</span></dt><dd>The LDS belief that all human spirits lived with God as His spirit children before being born on earth.</dd></dl>
      <dl class="term lds"><dt>Primary <span class="badge lds">LDS</span></dt><dd>The children's organization of the church, providing Sunday classes and activities for kids up to age 11.</dd></dl>
    </div>

    <!-- Q -->
    <div class="letter-group" id="letter-q" data-letter="Q">
      <div class="letter-head">Q</div>
      <dl class="term lds"><dt>Quorum of the Twelve Apostles <span class="badge lds">LDS</span></dt><dd>The second-highest governing body of the church, twelve men regarded as apostles and prophets, second in authority to the First Presidency.</dd></dl>
    </div>

    <!-- R -->
    <div class="letter-group" id="letter-r" data-letter="R">
      <div class="letter-head">R</div>
      <dl class="term lds"><dt>Relief Society <span class="badge lds">LDS</span></dt><dd>The church's organization for adult women — one of the oldest and largest women's organizations in the world, focused on service, faith, and community.</dd></dl>
      <dl class="term lds"><dt>Restoration <span class="badge lds">LDS</span></dt><dd>The LDS belief that Joseph Smith restored the original church, priesthood, and doctrines of Christ after the Great Apostasy — the defining premise of the faith.</dd></dl>
    </div>

    <!-- S -->
    <div class="letter-group" id="letter-s" data-letter="S">
      <div class="letter-head">S</div>
      <dl class="term shared"><dt>Sacrament <span class="badge lds">LDS</span></dt><dd>In LDS usage, the weekly ordinance of bread and water taken in remembrance of Christ — equivalent to Communion or the Eucharist in other traditions.</dd></dl>
      <dl class="term lds"><dt>Sealing <span class="badge lds">LDS</span></dt><dd>A temple ordinance binding family relationships — especially marriage — for eternity rather than only "till death do us part."</dd></dl>
      <dl class="term main"><dt>Sola Scriptura / Sola Fide <span class="badge main">Mainstream</span></dt><dd>Two of the Protestant "Five Solas": scripture alone as authority, and faith alone for salvation. Both stand in contrast to LDS belief in open canon and faith plus ordinances.</dd></dl>
      <dl class="term lds"><dt>Stake <span class="badge lds">LDS</span></dt><dd>An administrative grouping of several wards, led by a stake president — comparable to a diocese.</dd></dl>
      <dl class="term lds"><dt>Standard Works <span class="badge lds">LDS</span></dt><dd>The four-book LDS canon: the Bible, the Book of Mormon, the Doctrine &amp; Covenants, and the Pearl of Great Price.</dd></dl>
    </div>

    <!-- T -->
    <div class="letter-group" id="letter-t" data-letter="T">
      <div class="letter-head">T</div>
      <dl class="term lds"><dt>Telestial Kingdom <span class="badge lds">LDS</span></dt><dd>The lowest of the three degrees of glory in LDS afterlife theology.</dd></dl>
      <dl class="term lds"><dt>Temple Recommend <span class="badge lds">LDS</span></dt><dd>A certificate, issued after interviews confirming worthiness, that permits a member to enter the temple.</dd></dl>
      <dl class="term lds"><dt>Terrestrial Kingdom <span class="badge lds">LDS</span></dt><dd>The middle of the three degrees of glory.</dd></dl>
      <dl class="term main"><dt>Theosis <span class="badge main">Mainstream</span></dt><dd>The Eastern Orthodox doctrine that humans can partake of the divine nature and become "by grace" what God is "by nature." Often compared to — but distinct from — LDS exaltation.</dd></dl>
      <dl class="term shared"><dt>Tithing <span class="badge shared">Shared</span></dt><dd>Donating one-tenth of one's income. In the LDS Church it is a requirement for a temple recommend; most other churches encourage but do not require it.</dd></dl>
      <dl class="term main"><dt>Trinity <span class="badge main">Mainstream</span></dt><dd>The mainstream Christian doctrine of one God in three co-equal, co-eternal persons of one substance — Father, Son, and Holy Spirit. Rejected by LDS in favor of the Godhead.</dd></dl>
    </div>

    <!-- W -->
    <div class="letter-group" id="letter-w" data-letter="W">
      <div class="letter-head">W</div>
      <dl class="term lds"><dt>Ward <span class="badge lds">LDS</span></dt><dd>A local LDS congregation, typically a few hundred members defined by geographic boundaries, led by a bishop.</dd></dl>
      <dl class="term lds"><dt>Word of Wisdom <span class="badge lds">LDS</span></dt><dd>The LDS health code (revealed 1833) prohibiting alcohol, tobacco, coffee, tea, and illegal drugs, and encouraging healthy living.</dd></dl>
    </div>

  </div>

  <div class="no-results" id="no-results">No terms match your search.</div>

</main>

<footer>
  This page is for educational and informational purposes. Definitions are summarized in good faith. &copy; 2026
</footer>

<script>
  // Build alphabet nav from present letter groups
  (function () {
    var groups = document.querySelectorAll('.letter-group');
    var nav = document.getElementById('alpha-nav');
    groups.forEach(function (g) {
      var letter = g.getAttribute('data-letter');
      var a = document.createElement('a');
      a.href = '#letter-' + letter.toLowerCase();
      a.textContent = letter;
      nav.appendChild(a);
    });
  })();

  // Live filter
  (function () {
    var input = document.getElementById('glossary-search');
    var terms = Array.prototype.slice.call(document.querySelectorAll('.term'));
    var groups = Array.prototype.slice.call(document.querySelectorAll('.letter-group'));
    var noResults = document.getElementById('no-results');

    input.addEventListener('input', function () {
      var q = input.value.trim().toLowerCase();
      var anyVisible = false;

      terms.forEach(function (t) {
        var match = q === '' || t.textContent.toLowerCase().indexOf(q) !== -1;
        t.style.display = match ? '' : 'none';
        if (match) anyVisible = true;
      });

      // Hide a letter group if all its terms are hidden
      groups.forEach(function (g) {
        var visibleTerms = g.querySelectorAll('.term');
        var hasVisible = Array.prototype.some.call(visibleTerms, function (t) {
          return t.style.display !== 'none';
        });
        g.style.display = hasVisible ? '' : 'none';
      });

      noResults.style.display = anyVisible ? 'none' : 'block';
    });
  })();
</script>
{% endblock %}
